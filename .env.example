# Copy this file to .env and fill in your keys. Never commit .env itself.

# --- Web search ---
# Serper.dev API key — powers web search via SerperDevTool (Research, Contact).
# Free tier available at https://serper.dev/
SERPER_API_KEY=

# Tavily API key — powers TavilySearchTool (Profiler verification).
# Free tier available at https://tavily.com/
TAVILY_API_KEY=

# --- Model selection (provider-agnostic) ---
# A model is a LiteLLM string: "<provider>/<model>", e.g.
#   anthropic/claude-sonnet-4-6
#   openai/gpt-5.4-mini
#   gemini/gemini-1.5-pro
#
# DEFAULT_MODEL is the fallback for every agent. Override any single agent
# with its own model below — they can use different providers.
DEFAULT_MODEL=openai/gpt-5.4-mini
RESEARCH_MODEL=
PROFILER_MODEL=
CONTACT_MODEL=
BRIEF_MODEL=

# --- Provider API keys (set whichever providers you actually use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

CREWAI_TRACING_ENABLED=false

# --- Testing ---
# 1 = run the opt-in live integration test (real API calls); 0 = skip it.
RUN_LIVE=0
