# Copy this file to .env and fill in your keys. Never commit .env itself.

# --- Web search ---
# Serper.dev API key — powers web search via SerperDevTool.
# Free tier available at https://serper.dev/
SERPER_API_KEY=

# --- Model selection (provider-agnostic) ---
# A model is a LiteLLM string: "<provider>/<model>", e.g.
#   anthropic/claude-sonnet-4-6
#   openai/gpt-4o
#   gemini/gemini-1.5-pro
#
# DEFAULT_MODEL is the fallback for every agent. Override any single agent
# with its own model below — they can use different providers.
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
RESEARCH_MODEL=
PROFILER_MODEL=
CONTACT_MODEL=
BRIEF_MODEL=

# --- Provider API keys (set whichever providers you actually use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
